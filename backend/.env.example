# Postgres — create the DB/role first (see README), then fill this in.
DATABASE_URL=

# Leave blank to run the pipeline in mock mode (deterministic placeholder
# prompts/images) so the full flow works end to end without real API access.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image


STORAGE_ROOT=./storage

# Cloudinary — durable copy of storage_root. Leave all blank to run
# local-disk-only (fine for local dev). Required for a real deploy on a host
# without a persistent disk (e.g. Render free web service), since local
# storage_root can be wiped on restart/scale-to-zero there. Get these from
# the Cloudinary dashboard (cloudinary.com/console).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Module 3 — Image Quality Agent
QUALITY_PASS_THRESHOLD=80
QUALITY_MAX_RETRIES=0
NEAR_DUPLICATE_MAX_RETRIES=2
QUALITY_HARD_FAILURE_THRESHOLD=30

# Module 1 — Batch Image Generator
BATCH_MIN_IMAGES=1
BATCH_MAX_IMAGES=100

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Facebook/Instagram auto-posting (Meta Graph API). Leave FACEBOOK_APP_ID/
# SECRET blank to run in mock mode (simulated connect/publish, no real Meta
# App needed). Create a Meta App at developers.facebook.com to get real
# values; while the app is in Development mode, only accounts added as
# Admin/Developer/Tester on that app can connect. Going live for other
# salons requires Meta App Review + Business Verification, submitted by you
# in the Meta dashboard — not something this codebase can do for you.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/social/connect/facebook/callback

# Fernet key encrypting stored Facebook/Instagram access tokens at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Signs the httpOnly session cookie issued on register/login (each salon
# registers its own account — see app/routers/auth.py).
SESSION_SECRET_KEY=change-me-to-a-long-random-string

# Hours before a scheduled post's target datetime that AI content
# (caption/hashtags) is generated and queued for review.
CONTENT_LEAD_TIME_HOURS=24

# This backend's own public URL (e.g. https://your-app.onrender.com) — Meta
# Graph API needs to fetch the generated image over the internet when
# publishing for real. Not needed in mock mode or local-only development.
PUBLIC_BASE_URL=

# Optional: any endpoint that accepts a JSON POST (Slack/Discord incoming
# webhook, Zapier/Make catch hook). Every Notification is also delivered here
# so you don't have to keep the app open. Leave blank for in-app only.
NOTIFICATION_WEBHOOK_URL=

# Auto-refill: opt in per campaign (see campaign settings in the app). If a
# campaign has fewer than AUTO_REFILL_MIN_BUFFER_POSTS upcoming posts within
# AUTO_REFILL_BUFFER_DAYS, a new batch is auto-generated by cloning its last
# completed batch's design/pose images (capped by AUTO_REFILL_COOLDOWN_HOURS
# between refills per campaign, to bound cost).
AUTO_REFILL_BUFFER_DAYS=7
AUTO_REFILL_MIN_BUFFER_POSTS=3
AUTO_REFILL_COOLDOWN_HOURS=24
