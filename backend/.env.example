# Postgres — create the DB/role first (see README), then fill this in.
DATABASE_URL=

# Leave blank to run the pipeline in mock mode (deterministic placeholder
# prompts/images) so the full flow works end to end without real API access.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image


STORAGE_ROOT=./storage

# Cloudflare R2 (S3-compatible) — durable copy of storage_root. Leave all
# blank to run local-disk-only (fine for local dev). Required for a real
# deploy on a host without a persistent disk (e.g. Render free web service),
# since local storage_root can be wiped on restart/scale-to-zero there.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Module 3 — Image Quality Agent
QUALITY_PASS_THRESHOLD=80
QUALITY_MAX_RETRIES=3

# Module 1 — Batch Image Generator
BATCH_MIN_IMAGES=1
BATCH_MAX_IMAGES=100

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
